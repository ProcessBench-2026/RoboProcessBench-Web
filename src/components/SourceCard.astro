---
export interface Props {
  name: string;
  description: string;
}

const { name, description } = Astro.props;
---

<div
  class="flex flex-col rounded-xl border border-border bg-card p-5 transition-shadow hover:shadow-sm"
>
  <h4 class="!mt-0 text-base font-bold text-primary">{name}</h4>
  <p class="text-sm text-muted-foreground">{description}</p>
</div>
