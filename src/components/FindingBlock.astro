---
export interface Props {
  number: number;
  title: string;
}

const { number, title } = Astro.props;
---

<div class="flex items-start gap-3 rounded-lg border-l-[3px] border-secondary bg-muted/50 p-4">
  <span class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-secondary text-xs font-bold text-secondary-foreground">
    {number}
  </span>
  <p class="!my-0 text-sm">
    <strong class="text-card-foreground">Finding {number}:</strong>{" "}
    <span class="text-muted-foreground">{title}</span>
  </p>
</div>
