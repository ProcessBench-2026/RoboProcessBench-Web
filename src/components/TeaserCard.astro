---
export interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---

<div
  class="flex flex-col items-start rounded-xl border border-border bg-card p-6 text-left transition-shadow hover:shadow-md"
>
  {
    icon && (
      <div class="mb-3 text-2xl text-secondary" set:html={icon} />
    )
  }
  <h3 class="!mt-0 text-lg font-semibold text-card-foreground">{title}</h3>
  <p class="text-sm text-muted-foreground">{description}</p>
</div>
